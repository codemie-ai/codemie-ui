{
  "name": "ai-assistant",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "build:prod": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "format": "prettier --write src/ && npm run lint:fix",
    "react-format": "prettier --write src/react",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.tsx,.ts --ignore-path .gitignore",
    "lint:fix": "npm run lint -- --fix",
    "all:fix": "npm run format && npm run lint:fix",
    "check:pre-commit": "npm run typecheck && npm run lint",
    "prepare": "husky",
    "build:keycloak": "VITE_ENTRY=keycloakify npm run build:prod && npx keycloakify build",
    "start:keycloak": "source .env && sed -e \"s|\\${KC_ENTRA_TENANT_ID}|$KC_ENTRA_TENANT_ID|g\" -e \"s|\\${KC_ENTRA_CLIENT_ID}|$KC_ENTRA_CLIENT_ID|g\" -e \"s|\\${KC_ENTRA_CLIENT_SECRET}|$KC_ENTRA_CLIENT_SECRET|g\" .keycloakify/realm-kc-26.template.json > .keycloakify/realm-kc-26.json && VITE_ENTRY=keycloakify npx keycloakify start-keycloak --keycloak-version 26.4.5 2>&1 | sed 's|https://my-theme.keycloakify.dev/?port=8888|http://localhost:8888/realms/myrealm/account|g'",
    "mock-server": "json-server --watch mock-server/db.json --routes mock-server/routes.json --port 8080",
    "license-check": "npx license-checker --summary --onlyAllow 'MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense;BlueOak-1.0.0;Python-2.0;CC-BY-4.0;Apache*;(MIT OR CC0-1.0);MulanPSL-2.0;MPL-2.0;LGPL-3.0-only;UNLICENSED'",
    "license-headers:check": "node scripts/license_headers/check_license_headers.mjs --check",
    "license-headers:fix": "node scripts/license_headers/check_license_headers.mjs --fix",
    "license-headers": "npm run license-headers:fix && npm run license-headers:check",
    "secrets:check": "docker run --rm -v \"$(pwd):/path\" zricethezav/gitleaks:v8.30.0 dir --no-banner --verbose /path"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.3.0",
    "@dnd-kit/helpers": "^0.3.0",
    "@dnd-kit/react": "^0.3.0",
    "@floating-ui/react": "^0.27.8",
    "@hookform/resolvers": "^5.0.1",
    "@popperjs/core": "^2.11.8",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/dagre": "^0.7.53",
    "@types/diff": "^7.0.2",
    "@types/lodash": "^4.17.16",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.4.1",
    "@xyflow/react": "^12.8.6",
    "ace-builds": "^1.36.2",
    "axios": "1.13.2",
    "bootstrap-icons": "^1.11.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "diff": "^8.0.2",
    "dompurify": "^3.2.4",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "keycloakify": "^11.15.0",
    "lodash": "^4.17.21",
    "luxon": "^3.5.0",
    "marked": "^4.0.14",
    "primereact": "^10.9.5",
    "prismjs": "^1.29.0",
    "quill": "^2.0.2",
    "quill-image-drop-and-paste": "^2.0.1",
    "quill-mention": "^6.0.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0",
    "react-hook-form": "^7.56.3",
    "react-infinite-scroll-hook": "^5.0.2",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.5",
    "react-syntax-highlighter": "^16.1.0",
    "react-tooltip": "^5.29.1",
    "react-zoom-pan-pinch": "^3.7.0",
    "save-html-as-image": "^1.7.1",
    "tailwind-merge": "^3.3.0",
    "toastify-js": "^1.12.0",
    "uuid": "^9.0.0",
    "valtio": "^2.1.4",
    "vee-validate": "^4.11.8",
    "vite-plugin-prismjs": "^0.0.8",
    "yup": "^1.3.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@rushstack/eslint-patch": "^1.2.0",
    "@stylistic/eslint-plugin": "^2.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.29",
    "@types/react-datepicker": "^6.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-istanbul": "^1.6.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-sonarjs": "^2.0.4",
    "husky": "^9.1.7",
    "jsdom": "^24.1.0",
    "json-server": "^0.17.4",
    "lint-staged": "^15.3.1",
    "postcss": "^8.4.35",
    "prettier": "^2.8.8",
    "sass": "^1.63.4",
    "tailwindcss": "^3.4.1",
    "tailwindcss-themer": "^4.1.1",
    "typescript": "^5.4.2",
    "vite": "^5.0.11",
    "vite-plugin-svgr": "^4.3.0",
    "vite-svg-loader": "^5.1.0",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": [
      "prettier --write",
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ],
    "src/**/*.{js,jsx,ts,tsx,cjs,mjs}": [
      "node scripts/license_headers/check_license_headers.mjs --fix"
    ],
    "src/**/*.{css,scss}": [
      "node scripts/license_headers/check_license_headers.mjs --fix"
    ],
    "*.{json,md,html,css,scss}": [
      "prettier --write"
    ]
  }
}
