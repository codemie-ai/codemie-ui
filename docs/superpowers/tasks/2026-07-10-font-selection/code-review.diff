+      }
+    )
+
+    it('rejects invalid codeBlockFontStack value', () => {
+      const preset = {
+        ...userPreset,
+        values: { ...userPreset.values, codeBlockFontStack: 'courier-new' },
+      }
+      expect(() => validateImportedPreset(preset)).toThrow()
+    })
+  })
 })
