+import { describe, it, expect, beforeEach, beforeAll } from 'vitest'
 
 import CodeBlock from '../CodeBlock'
 
@@ -96,3 +99,34 @@ describe('CodeBlock font rendering integration', () => {
     expect(cssVariable).toContain('IBM Plex Mono')
   })
